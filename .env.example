# --- Client (VITE_* — embedded in the browser bundle; use restricted keys) ---

# Cesium Ion default access token (terrain, imagery, etc.).
VITE_CESIUM_ION_TOKEN=

# Google Maps Platform — Photorealistic 3D Tiles and related APIs as used by the app.
VITE_GOOGLE_MAPS_API_KEY=

# Production: HTTPS origin of your API that mirrors /api/skyview/* (no trailing slash).
# Leave empty in dev; Vite proxies and middleware handle /api/skyview locally.
VITE_SKYVIEW_API_BASE_URL=

# Feature toggles (set to "false" to disable).
VITE_SKYVIEW_ENABLE_MINIMAP=
VITE_SKYVIEW_ENABLE_SATELLITES=
VITE_SKYVIEW_ENABLE_WEATHER=
VITE_SKYVIEW_ENABLE_CAMERAS=

# --- Server-only (read by vite.config.js in dev only; never VITE_-prefixed) ---

# OpenSky Network OAuth2 client credentials for POST /api/skyview/opensky/token.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# N2YO satellite API — proxied GET /api/skyview/n2yo/*
N2YO_API_KEY=

# Windy Webcams — proxied GET /api/skyview/windy/*
WINDY_WEBCAMS_API_KEY=
